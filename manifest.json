{
  "manifest_version": 3,
  "name": "Finn Pendle Tid",
  "version": "1.1.0",
  "description": "Sammenlign kollektiv pendletid og ren gangtid direkte i FINN-boligannonser.",
  "permissions": ["storage", "tabs", "webNavigation"],
  "host_permissions": [
    "https://www.finn.no/*",
    "https://api.entur.io/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Finn Pendle Tid",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.finn.no/realestate/homes/ad.html*",
        "https://www.finn.no/realestate/lettings/ad.html*"
      ],
      "css": ["content.css"],
      "js": ["content.js"]
    }
  ]
}
